# 1. Limpiamos cualquier rastro de configuración previa en la sesión
unloadNamespace("renv")
# 2. Instalamos renv en la carpeta de R-Portable (o tu R principal)
# para que sea el "maestro"
install.packages("renv", lib = .Library)
# 3. Forzamos a que R use ESTA carpeta y no el sandbox de AppData
Sys.setenv(RENV_CONFIG_SANDBOX_ENABLED = FALSE)
Sys.setenv(RENV_CONFIG_CACHE_ENABLED = FALSE)
# 4. Inicializamos el proyecto
# Si te pregunta (1, 2, 3...), elige la opción 2 (Discard and re-initialize)
renv::init(bare = TRUE, restart = FALSE)
# 5. Aseguramos que el tipo sea explicit
renv::settings$snapshot.type("explicit")
.libPaths()
# 1. Moverse a la carpeta del código
setwd("C:/Users/Legion/bulk/MyInstallers/RMedic3_2026_installer/RMedic3_2026")
# 2. Inicializar renv AQUÍ (dentro de RMedic3_2026)
# Esto creará una nueva carpeta 'renv' dentro de RMedic3_2026
renv::init(bare = TRUE)
